NODE_ENV=production
HOST=0.0.0.0
PORT=3001
REPRICER_PROCESS_MODE=all

# Required secret (min 16 chars)
REPRICER_MASTER_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Runtime directories
DATA_DIR=/opt/wb-repricer/data
LOG_DIR=/opt/wb-repricer/logs
TMP_DIR=/opt/wb-repricer/tmp
STORAGE_DIR=/opt/wb-repricer/storage

DATABASE_URL=file:/opt/wb-repricer/data/repricer.db
REPRICER_WEB_DIST_DIR=/opt/wb-repricer/apps/web/dist
REPRICER_PUBLIC_DIR=/opt/wb-repricer/public

# Seller token can be bootstrapped from env (optional)
WB_API_TOKEN=

# Safety-first rollout
REPRICER_DRY_RUN=true
REPRICER_DISABLE_CRON_MONITOR=false
REPRICER_MONITOR_INTERVAL=1
REPRICER_CRON_ENFORCE=*/10 * * * *
REPRICER_ENFORCE_CRON_DRY_RUN=true

# Buyer session persistence
BUYER_PROFILE_DIR=/opt/wb-repricer/storage/buyer-profile
BUYER_STATE_PATH=/opt/wb-repricer/storage/buyer/storage-state.json
REPRICER_BUYER_VERIFY_MODE=cookies_only
SESSION_REFRESH_FLAGS=login_bootstrap,auto_refresh

# Browser
BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
HEADLESS=true

# Existing repricer knobs
REPRICER_WALLET_DEST=
REPRICER_MONITOR_WALLET_BATCH=true
REPRICER_MONITOR_SPP_VIA_COOKIES=true
REPRICER_MONITOR_CARD_API_MAX_ATTEMPTS=3
REPRICER_MIN_VALID_REGIONS_FOR_ENFORCE=1
REPRICER_MIN_WALLET_PARSE_CONFIDENCE=0.5

REPRICER_ADMIN_PASSWORD=
REPRICER_CORS_ORIGINS=

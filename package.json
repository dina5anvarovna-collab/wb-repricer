{
  "name": "wb-repricer-server",
  "version": "0.1.0",
  "description": "WB: парсинг цен (кабинет + Кошелёк), целевая цена, мониторинг — без учёта прибыли",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "npm run build --prefix apps/web",
    "build:all": "npm run build && npm run build:web",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:web": "npm run dev --prefix apps/web",
    "start": "node dist/server.js",
    "start:api": "REPRICER_PROCESS_MODE=api node dist/server.js",
    "start:web": "REPRICER_PROCESS_MODE=web node dist/webServer.js",
    "start:worker": "REPRICER_PROCESS_MODE=worker node dist/worker.js",
    "start:monitor": "REPRICER_PROCESS_MODE=worker node dist/worker.js",
    "install:all": "npm install && npm install --prefix apps/web",
    "launch": "npm run build:all && node dist/server.js",
    "first-run": "npm run install:all && npx prisma db push && npm run build:all && node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "wallet:login": "npm run build && node dist/walletDom/cli.js --login=true --headless=false --browser=chromium",
    "wallet:login:chrome": "npm run build && node dist/walletDom/cli.js --login=true --headless=false --browser=chrome"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.2",
    "@prisma/client": "^6.3.1",
    "adm-zip": "^0.5.16",
    "axios": "1.7.9",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.59.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}

# Copy to .env — never commit .env
NODE_ENV=development
# 0.0.0.0 — удобно для localhost и IPv4; только локально без сети можно HOST=127.0.0.1
HOST=0.0.0.0
PORT=3001
REPRICER_PROCESS_MODE=all

# Runtime directories (server-safe layout)
DATA_DIR=./data
LOG_DIR=./logs
TMP_DIR=./tmp
STORAGE_DIR=./storage

# AES-256-GCM (≥16 символов). В development можно не задавать — подставится dev-default (см. console.warn).
REPRICER_MASTER_SECRET=

DATABASE_URL=file:./data/repricer.db
REPRICER_WEB_DIST_DIR=./apps/web/dist
REPRICER_PUBLIC_DIR=./public

# Optional environment bootstrap token for seller API (can be left empty if saved in DB via UI)
WB_API_TOKEN=
# Generic dry-run alias (maps to REPRICER_ENFORCE_CRON_DRY_RUN)
REPRICER_DRY_RUN=true
# Fallback monitor interval (hours) if app setting is not initialized yet
REPRICER_MONITOR_INTERVAL=1

# Browser runtime
BROWSER_EXECUTABLE_PATH=
HEADLESS=true
SESSION_REFRESH_FLAGS=login_bootstrap,auto_refresh

# Wallet DOM CLI (после npm run build — dist/walletDom/cli.js)
REPRICER_WALLET_CLI_PATH=./dist/walletDom/cli.js
# Корень проекта для cwd процесса node (обычно каталог WB_Repricer)
REPRICER_WALLET_PROJECT_ROOT=.

# PUBLIC ONLY (по умолчанию): только публичная витрина + popup; без buyer-login, без refresh кук как часть основного контура.
REPRICER_DISABLE_BUYER_AUTH=true
REPRICER_WALLET_PARSE_MODE=public_only
REPRICER_WALLET_DETAILS_MODE=popup_first

# Профиль покупателя WB (legacy; при REPRICER_DISABLE_BUYER_AUTH=true не используется основным пайплайном)
REPRICER_BUYER_PROFILE_DIR=.wb-browser-profile
BUYER_PROFILE_DIR=./storage/buyer-profile
BUYER_STATE_PATH=./storage/buyer/storage-state.json

# Автозапуск окна входа WB после кнопки «Получить команду…» (пусто = на macOS да, на Linux — только вручную в терминале)
# REPRICER_BUYER_LOGIN_AUTOSPAWN=1
# После «Подтвердить вход»: если headless-проверка не прошла — второй раз с видимым окном (пусто = на macOS да)
# REPRICER_BUYER_VERIFY_HEADED_RETRY=1

# Сервер без GUI: «Подтвердить вход» и refresh без полной карточки товара (главная WB + куки + card).
# Либо импортируйте JSON: POST /api/settings/buyer-session/import-storage-state (тело = Playwright storageState с ПК после входа).
# REPRICER_BUYER_VERIFY_MODE=cookies_only

# npm run wallet:login — теперь по умолчанию Google Chrome (Mac). Без Chrome: npm run wallet:login:chromium и npx playwright install chromium
# Браузер Playwright: chrome | chromium. На Mac по умолчанию Chrome из /Applications (Stable / Canary / Beta).
# Если окно не открывается — попробуйте REPRICER_DOM_BROWSER=chromium или укажите путь:
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# REPRICER_DOM_BROWSER=chromium

# Только для npm run dev:web: куда проксировать /api, если API не на 3001
# VITE_DEV_API_PROXY=http://127.0.0.1:3001
# VITE_DEV_WEB_PORT=5173

# Playwright storageState (cookies витрины) — обновляется через «Сессия WB» или refresh в коде
# REPRICER_WB_STORAGE_STATE_PATH=./data/wb-buyer-storage-state.json

# 1/true — каждый час полная синхронизация каталога (Seller API + снимки цен/остатков в БД)
# REPRICER_CRON_CATALOG_SYNC_HOURLY=true

# Остатки в WbProduct.stock: после цен вызывается Statistics API supplier/stocks (нужна категория «Статистика» у того же или отдельного ключа)
# REPRICER_SYNC_STATISTICS_STOCKS=true
# REPRICER_WB_STATISTICS_TOKEN=
# Пауза между страницами отчёта (лимит WB ~1 запрос/мин)
# REPRICER_WB_STATISTICS_PAUSE_MS=61000

# Интервал мониторинга задаётся в админке (Настройки → часы). Переменная ниже больше не используется планировщиком.
# REPRICER_CRON_SYNC=0 */2 * * *

# Плановый мониторинг по минутному таймеру. В development, если строку не задать, сервер сам подставит отключение (true), чтобы не блокировать ручной запуск.
# REPRICER_DISABLE_CRON_MONITOR=false

# Мониторинг: пауза между шагами (мс) и таймаут одной карточки WB. Каждый шаг = новый процесс + браузер — прогон длинный; 0 = без паузы между шагами.
# REPRICER_MONITOR_BATCH_PAUSE_MS=200
# REPRICER_MONITOR_WALLET_TIMEOUT_MS=300000

# Мониторинг: один браузер на весь прогон (быстро). false — старый режим: отдельный процесс на каждый nm×регион.
# REPRICER_MONITOR_WALLET_BATCH=true
# Пауза между карточками в batch (мс), внутри одного контекста Playwright.
# REPRICER_MONITOR_BATCH_INTER_STEP_MS=1200
# Таймаут networkidle на карточке WB (мс). По умолчанию 90000; 25000–35000 ускоряет мониторинг, но выше риск неполной загрузки DOM.
# REPRICER_WALLET_NETWORKIDLE_MS=90000
# Не открывать модалку «Детализация цены» (быстрее прогон, слабее разбор 401/414/600 с витрины).
# Для public-first оставьте false/пусто, чтобы сначала витрина, затем popup.
# REPRICER_WALLET_SKIP_PRICE_DETAILS_MODAL=true

# Порядок источников (legacy при REPRICER_DISABLE_BUYER_AUTH=false): public_then_cookies | public_only | …
# REPRICER_WALLET_PARSE_MODE=public_then_cookies
# Режим проверки buyer: public_first | cookies_only | strict | …
# REPRICER_BUYER_VERIFY_MODE=public_first
# Явный автозапуск окна входа после login/start (0/false — для systemd/VPS)
# REPRICER_BUYER_LOGIN_AUTOSTART=false
# Не вызывать refresh кук перед мониторингом (использовать файл на диске как есть)
# REPRICER_MONITOR_SKIP_COOKIE_REFRESH_BEFORE_JOB=false
# TTL глобального lock монитор/enforce (мин); после падения процесса lock снимется по TTL или при старте сервиса
# REPRICER_SCHEDULER_LOCK_TTL_MIN=90
# Интерактивный браузер на сервере Linux без DISPLAY — по умолчанию недоступен; true только с X11
# REPRICER_HEADED_LOGIN_ALLOWED=false
# Авто-очистка artifacts/wb-wallet (по возрасту и количеству файлов).
# REPRICER_WALLET_ARTIFACTS_MAX_FILES=300
# REPRICER_WALLET_ARTIFACTS_MAX_AGE_HOURS=24

# Витрина/СПП: при buyer auth выключен автоматически false в коде (без card.wb.ru по cookies).
# REPRICER_MONITOR_SPP_VIA_COOKIES=false
# REPRICER_MONITOR_CARD_API_MAX_ATTEMPTS=3

# Регион витрины WB (dest из GET /api/regions или data/wb-regions.json) — влияет на цену/СПП/«Кошелёк» при парсинге
# Пример Москва: -1257786
REPRICER_WALLET_DEST=

# Удержание цены: допуск к цели (₽), макс. изменение цены в кабинете за один проход (%)
REPRICER_ENFORCE_TOLERANCE_RUB=3
REPRICER_ENFORCE_MAX_STEP_PERCENT=20

# Опционально: cron удержания (пусто = отключено). В боевом режиме выставьте REPRICER_ENFORCE_CRON_DRY_RUN=false
# REPRICER_CRON_ENFORCE=20 */2 * * *
REPRICER_CRON_ENFORCE=
REPRICER_ENFORCE_CRON_DRY_RUN=true

# Минимальная уверенность парсера кошелька (0..1) для реальной выгрузки цены в кабинет
REPRICER_MIN_WALLET_PARSE_CONFIDENCE=0.5
# Safety model (анти-аномалии и rails для авто-репрайса)
REPRICER_SHOWCASE_MIN_RATIO_TO_SELLER=0.45
REPRICER_SHOWCASE_MAX_RATIO_TO_SELLER=1.9
REPRICER_SHOWCASE_MAX_JUMP_PCT=45
REPRICER_MAX_PROPOSED_CHANGE_PCT=35
REPRICER_MAX_UPDATES_PER_DAY_PER_SKU=4
REPRICER_MIN_VALID_REGIONS_FOR_ENFORCE=1
REPRICER_REGION_STABILITY_MAX_SPREAD_PCT=20

# Пароль панели (пусто = без авторизации API). После установки: POST /api/auth/login → Bearer token
REPRICER_ADMIN_PASSWORD=

# CORS для dev UI (Vite :5173). Пример: http://127.0.0.1:5173,http://localhost:5173
REPRICER_CORS_ORIGINS=

# Опционально: Telegram-уведомления (кнопка теста в /admin.html)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Публичный парсинг Playwright (PUBLIC_ONLY / проба карточки на /session) ---
# REPRICER_PUBLIC_BROWSER_HEADLESS=true
# REPRICER_PUBLIC_BROWSER_CHANNEL=chromium
# Пустой — разумный Chrome-подобный UA (см. src/lib/publicBrowserRuntime.ts)
# REPRICER_PUBLIC_BROWSER_USER_AGENT=
# REPRICER_PUBLIC_BROWSER_LOCALE=ru-RU
# REPRICER_PUBLIC_BROWSER_TIMEZONE=Europe/Moscow
# REPRICER_PUBLIC_BROWSER_VIEWPORT_WIDTH=1366
# REPRICER_PUBLIC_BROWSER_VIEWPORT_HEIGHT=900
# REPRICER_PUBLIC_BROWSER_SLOWMO_MS=0
# REPRICER_PUBLIC_BROWSER_EXTRA_WAIT_MS=2000
# REPRICER_PUBLIC_BROWSER_JITTER_MS=3000
# Файлы отладки (до 20 последних в каталоге): snippet, screenshot, meta JSON
# REPRICER_PUBLIC_PARSE_DEBUG=false
# REPRICER_PUBLIC_PARSE_DEBUG_DIR=/opt/WB_Repricer/tmp/public-parse-debug
# Опционально только для публичного парсинга:
# REPRICER_PUBLIC_PROXY_SERVER=http://127.0.0.1:8888
# REPRICER_PUBLIC_PROXY_USERNAME=
# REPRICER_PUBLIC_PROXY_PASSWORD=
